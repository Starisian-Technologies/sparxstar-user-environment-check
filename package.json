{
  "name": "sparxstar-user-environment-check",
  "version": "1.0.0",
  "private": true,
  "description": "WordPress plugin for browser, device, and environment diagnostics using a modern ES Module architecture.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Starisian Technologies",
  "scripts": {
    "lint:js": "eslint src/js/",
    "lint:css": "stylelint src/css/",
    "lint": "pnpm run lint:js && pnpm run lint:css",
    "format": "eslint src/js/ --fix && stylelint src/css/ --fix",
    "clean": "rm -rf assets",
    "validate": "node validate-build.cjs",

"build:css": "postcss src/css/sparxstar-user-environment-check.css -o assets/css/sparxstar-user-environment-check.min.css",

    "build:js": "rollup -c roll-up.config.mjs",
    "build": "pnpm run validate && pnpm run clean && mkdir -p assets/js && pnpm run build:css && pnpm run build:js",
    "version:sync": "node sync-version.js"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "cssnano": "^7.1.2",
    "eslint": "^9.39.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "rollup": "^4.53.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.0.1",
    "device-detector-js": "^3.0.3"
  },
  "packageManager": "pnpm@8.6.0",
  "pnpm": {
    "overrides": {
      "rollup@>=4.0.0 <4.22.4": ">=4.22.4",
      "semver": ">=7.5.2",
      "glob": ">=11.1.0"    }
  }
}
