{
  "name": "sparxstar-user-environment-check",
  "version": "0.9.1",
  "private": true,
  "description": "WordPress plugin for browser, device, and environment diagnostics using a modern ES Module architecture.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Starisian Technologies",
  "scripts": {
    "lint:js": "eslint src/js/",
    "lint:css": "stylelint src/css/",
    "lint": "pnpm run lint:js && pnpm run lint:css",
    "lint:fix": "eslint src/js/ --fix",
    "format": "prettier --write \"src/**/*.{js,css}\"",
    "fix": "pnpm run lint:fix && pnpm run stylelint:fix && pnpm run format",
    "stylelint:fix": "stylelint \"src/css/**/*.css\" --fix",
    "jsdocs": "node bin/generate-js-docs.mjs",
    "docs:all": "composer docs && pnpm run jsdocs",
    "clean": "rm -rf assets",
    "validate": "node validate-build.cjs",
    "build:css": "postcss src/css/sparxstar-user-environment-check.css -o assets/css/sparxstar-user-environment-check.min.css",
    "build:js": "rollup -c roll-up.config.mjs",
    "build:js:dev": "rollup -c roll-up.config.dev.mjs",
    "build": "pnpm run validate && pnpm run clean && mkdir -p assets/js && pnpm run build:css && pnpm run build:js",
    "build:dev": "pnpm run validate && pnpm run clean && mkdir -p assets/js && pnpm run build:css && pnpm run build:js:dev",
    "version:sync": "node sync-version.js"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "cssnano": "^7.1.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdoc": "^4.0.5",
    "jsdoc-to-markdown": "^9.1.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.1.0",
    "device-detector-js": "^3.0.3"
  },
  "packageManager": "pnpm@8.6.0",
  "pnpm": {
    "overrides": {
      "rollup@>=4.0.0 <4.22.4": ">=4.22.4",
      "semver": ">=7.5.2",
      "glob": ">=11.1.0",
      "tmp": ">=0.2.4",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "ajv@<6.14.0": ">=6.14.0"
    }
  }
}